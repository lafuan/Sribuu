# This is an example environment file.
# Copy this to .env and fill in your actual values.
# DO NOT COMMIT .env TO VERSION CONTROL.

# Generate a secure secret key. You can use: openssl rand -hex 32
SECRET_KEY="a_very_secure_secret_key_that_is_at_least_32_bytes_long"

# Database connection string
# For local PostgreSQL:
DATABASE_URL="postgresql+asyncpg://sribuu:sribuu_dev_2026@localhost:5432/sribuu"

# For SQLite (useful for quick tests):
# DATABASE_URL="sqlite+aiosqlite:///./test.db"

# Set to True for development to enable debug tracebacks
# In production, this MUST be False.
DEBUG="True"
